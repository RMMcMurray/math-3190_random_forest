library(randomForest)
library(caret)
library(ggplot2)
library(dplyr)
library(tidyr)
library(forcats)
library(reprtree)
data(iris)
#| label: Classification Initial Model
set.seed(42)
trainIndex <- sample(1:nrow(iris), 0.8 * nrow(iris))
trainData <- iris[trainIndex, ]
testData <- iris[-trainIndex, ]
rf_model <- randomForest(Species ~ ., data = trainData, type="classification", importance=T, proximity=T)
print(rf_model)
plot.getTree(rf_model, k = 1)
round(rf_model$importance, 2)
plot(rf_model, type = "l", main = "Error Vs. Number of Trees")
predictions <- predict(rf_model, testData)
confusionMatrix(predictions, testData$Species)
ctrl_random <- trainControl(method = "cv", number = 5, search = "random")
set.seed(123)
random_model <- train(
Species ~ .,
data = trainData,
method = "ranger",
tuneLength = 20,
trControl = ctrl_random
)
ntree_vals <- c(50, 100, 200, 300, 500)
oob_errors <- sapply(ntree_vals, function(n) {
rf <- randomForest(Species ~ ., data = trainData, ntree = n, mtry = 3, nodesize = 14)
rf$err.rate[n, "OOB"]
})
cat("\nBest Hyperparameters (Random Search):\n")
print(random_model$bestTune)
print(random_model$bestTune)
best_ntree <- ntree_vals[which.min(oob_errors)]
cat("Best ntree:", best_ntree, "\n")
set.seed(42)
rf_model_tune <- randomForest(Species ~ ., data = trainData, type="classification", importance=T, proximity=T, ntree=50, mktry=3, nodesize=14)
print(rf_model_tune)
imp <- importance(rf_model)
imp_df <- as.data.frame(imp) |>
tibble::rownames_to_column("Feature") |>
pivot_longer(
cols      = c(MeanDecreaseAccuracy, MeanDecreaseGini),
names_to  = "Metric",
values_to = "Importance"
) |>
mutate(
Metric  = recode(Metric,
MeanDecreaseAccuracy = "Mean Decrease Accuracy",
MeanDecreaseGini     = "Mean Decrease Gini"
),
Feature = fct_reorder(Feature, Importance, .fun = mean)
)
ggplot(imp_df, aes(x = Importance, y = Feature, fill = Metric)) +
geom_col(position = position_dodge(width = 0.6), width = 0.55, alpha = 0.88) +
facet_wrap(~Metric, scales = "free_x") +
scale_fill_manual(values = c("#2C7BB6", "#D7191C")) +
labs(
title    = "Feature Importance — Two Perspectives",
subtitle = "Accuracy: permutation-based  |  Gini: impurity-based",
x        = "Importance Score",
y        = NULL
) +
theme_minimal(base_size = 14) +
theme(
legend.position  = "none",
strip.text       = element_text(face = "bold"),
plot.title       = element_text(face = "bold"),
panel.grid.minor = element_blank()
)
err_df <- as.data.frame(rf_model$err.rate) |>
mutate(Trees = seq_len(n())) |>
pivot_longer(
cols      = -Trees,
names_to  = "Class",
values_to = "OOB_Error"
) |>
mutate(
Class     = recode(Class, OOB = "Overall OOB"),
LineType  = if_else(Class == "Overall OOB", "solid", "dashed"),
LineWidth = if_else(Class == "Overall OOB", 1.2, 0.7)
)
ggplot(err_df, aes(x = Trees, y = OOB_Error, colour = Class,
linetype = LineType, linewidth = LineWidth)) +
geom_line(alpha = 0.85) +
scale_linetype_identity() +
scale_linewidth_identity() +
scale_colour_manual(values = c(
"Overall OOB" = "#1a1a1a",
"setosa"      = "#4DAF4A",
"versicolor"  = "#377EB8",
"virginica"   = "#E41A1C"
)) +
scale_y_continuous(labels = scales::percent_format(accuracy = 1)) +
labs(
title    = "OOB Error Rate vs. Number of Trees",
subtitle = "Ensemble error stabilises rapidly; per-class error reveals which species remain hard to separate",
x        = "Number of Trees",
y        = "OOB Error Rate",
colour   = "Class"
) +
theme_minimal(base_size = 14) +
theme(
plot.title       = element_text(face = "bold"),
legend.position  = "right",
panel.grid.minor = element_blank()
)
err_df <- as.data.frame(rf_model$err.rate) |>
mutate(Trees = seq_len(n())) |>
pivot_longer(
cols      = -Trees,
names_to  = "Class",
values_to = "OOB_Error"
)
ggplot(err_df, aes(x = Trees, y = OOB_Error, colour = Class,
linetype = LineType, linewidth = LineWidth)) +
geom_line(alpha = 0.85) +
scale_linetype_identity() +
scale_linewidth_identity() +
scale_colour_manual(values = c(
"setosa"      = "#4DAF4A",
"versicolor"  = "#377EB8",
"virginica"   = "#E41A1C"
)) +
scale_y_continuous(labels = scales::percent_format(accuracy = 1)) +
labs(
