plot(rf_model, type = "l", main = "OOB Error vs. Number of Trees")
# Get per-tree votes by predicting on each tree individually
# votes matrix from the forest gives fraction of trees voting each class
votes_df <- as.data.frame(rf_model$votes) |>
tibble::rownames_to_column("obs_id") |>
mutate(
True_Label = trainData$Species,
obs_id     = as.integer(obs_id)
)
# Focus on the AMBIGUOUS observations (neither max class > 90%)
ambiguous <- votes_df |>
rowwise() |>
mutate(max_vote = max(c(setosa, versicolor, virginica))) |>
ungroup() |>
filter(max_vote < 0.85) |>
slice_min(max_vote, n = 12)
plot_df <- ambiguous |>
pivot_longer(
cols      = c(setosa, versicolor, virginica),
names_to  = "Voted_Class",
values_to = "Vote_Fraction"
) |>
mutate(
obs_label  = paste0("#", obs_id, "\n(", True_Label, ")"),
obs_label  = fct_reorder(obs_label, Vote_Fraction, .fun = max, .desc = TRUE)
)
ggplot(plot_df, aes(x = Voted_Class, y = Vote_Fraction, fill = Voted_Class)) +
geom_col(alpha = 0.85, width = 0.6) +
geom_hline(yintercept = 0.5, linetype = "dashed", colour = "grey40", linewidth = 0.5) +
facet_wrap(~obs_label, nrow = 2) +
scale_fill_manual(values = c(
"setosa"     = "#4DAF4A",
"versicolor" = "#377EB8",
"virginica"  = "#E41A1C"
)) +
scale_y_continuous(labels = scales::percent_format(), limits = c(0, 1)) +
labs(
title    = "Tree Vote Distributions for Ambiguous Observations",
subtitle = "Each bar = fraction of trees voting that class | dashed line = majority threshold",
x        = NULL,
y        = "Fraction of Tree Votes",
fill     = "Voted Class"
) +
theme_minimal(base_size = 12) +
theme(
plot.title       = element_text(face = "bold"),
strip.text       = element_text(size = 9),
legend.position  = "bottom",
panel.grid.minor = element_blank()
)
